{% extends "layouts/base.twig" %}

{% block title %}Vaultex — Криптовалютный кошелёк и обменник | Crypto Wallet & Exchange{% endblock %}

{% block body %}
<!-- Navigation -->
<nav class="navbar">
  <div class="container navbar__container">
    <a href="/" class="navbar__logo">
      <img src="/assets/images/logo.svg" alt="Vaultex" width="120">
    </a>
    <div class="navbar__actions">
      <a href="/login" class="btn btn--ghost">{{ lang('login.submit') }}</a>
      <a href="/register" class="btn btn--primary">{{ lang('hero.start') }}</a>
    </div>
  </div>
</nav>

<!-- Hero Section -->
<section class="hero">
  <div class="hero__bg"></div>
  <div class="container hero__container">
    <div class="hero__content">
      <span class="label hero__label">{{ lang('hero.label') }}</span>
      <h1 class="hero__title">{{ lang('hero.title')|raw }}</h1>
      <p class="hero__desc">{{ lang('hero.description') }}</p>
      <div class="hero__actions">
        <a href="/register" class="btn btn--primary btn--lg">{{ lang('hero.start') }}</a>
        <a href="#features" class="btn btn--ghost btn--lg">{{ lang('hero.more') }}</a>
      </div>
      <div class="hero__stats">
        <div class="stat">
          <span class="stat__value">{{ stats.users|number_format(0, '.', ' ') }}+</span>
          <span class="stat__label">Пользователей</span>
        </div>
        <div class="stat">
          <span class="stat__value">{{ stats.transactions|number_format(0, '.', ' ') }}+</span>
          <span class="stat__label">Транзакций</span>
        </div>
        <div class="stat">
          <span class="stat__value">{{ stats.countries }}+</span>
          <span class="stat__label">Стран</span>
        </div>
      </div>
    </div>
    <div class="hero__visual">
      <img src="/assets/images/hero-wallet-3d.png" alt="Vaultex Crypto Wallet" width="600" height="500">
    </div>
  </div>
</section>

<!-- Banners Carousel -->
{% if banners is not empty %}
<section class="banners">
  <div class="container">
    <div class="splide" id="banner-carousel">
      <div class="splide__track">
        <ul class="splide__list">
          {% for banner in banners %}
          <li class="splide__slide">
            <a href="{{ banner.link }}" class="banner-card">
              <img src="/assets/images/{{ banner.image }}" alt="{{ banner.alt_text }}" width="1200" height="400" loading="lazy">
              <div class="banner-card__text">
                <h2>{{ banner.title }}</h2>
                <p>{{ banner.subtitle }}</p>
              </div>
            </a>
          </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>
{% endif %}

<!-- Features Section -->
<section class="features" id="features">
  <div class="container">
    <h2 class="text-center mb-4">Всё что нужно для работы с криптовалютой</h2>
    <div class="grid grid--3">
      <div class="card feature-card">
        <div class="feature-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h3>Безопасное хранение</h3>
        <p>Ваши ключи зашифрованы и хранятся локально. Полный контроль над вашими активами.</p>
      </div>
      <div class="card feature-card">
        <div class="feature-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3>Мгновенное пополнение</h3>
        <p>Пополняйте баланс в любой криптовалюте. Подтверждение за считанные минуты.</p>
      </div>
      <div class="card feature-card">
        <div class="feature-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>
        </div>
        <h3>Быстрый вывод</h3>
        <p>Выводите средства на любые кошельки. Автоматическая обработка 24/7.</p>
      </div>
      <div class="card feature-card">
        <div class="feature-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3>История транзакций</h3>
        <p>Полная история всех операций. Экспорт в CSV для удобства учёта.</p>
      </div>
      <div class="card feature-card">
        <div class="feature-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
        </div>
        <h3>Двухфакторная защита</h3>
        <p>Дополнительный уровень безопасности с 2FA через Google Authenticator.</p>
      </div>
      <div class="card feature-card">
        <div class="feature-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3>P2P торговля</h3>
        <p>Покупайте и продавайте криптовалюту напрямую. Скоро в приложении.</p>
        <span class="label label--soon">Скоро</span>
      </div>
    </div>
  </div>
</section>

<!-- Supported Coins -->
<section class="coins">
  <div class="container">
    <h2 class="text-center mb-4">Поддерживаемые активы</h2>
    <div class="coins__scroll">
      <img src="/assets/icons/coins/btc.svg" alt="Bitcoin" width="48" height="48">
      <img src="/assets/icons/coins/eth.svg" alt="Ethereum" width="48" height="48">
      <img src="/assets/icons/coins/usdt.svg" alt="Tether" width="48" height="48">
      <img src="/assets/icons/coins/bnb.svg" alt="BNB" width="48" height="48">
      <img src="/assets/icons/coins/sol.svg" alt="Solana" width="48" height="48">
      <img src="/assets/icons/coins/usdc.svg" alt="USD Coin" width="48" height="48">
      <img src="/assets/icons/coins/trx.svg" alt="TRON" width="48" height="48">
      <img src="/assets/icons/coins/matic.svg" alt="Polygon" width="48" height="48">
    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="cta">
  <div class="container text-center">
    <h2>Готовы начать?</h2>
    <p class="mb-4">Создайте аккаунт бесплатно за 2 минуты</p>
    <a href="/register" class="btn btn--primary btn--xl">Создать кошелёк</a>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="container">
    <div class="grid grid--4">
      <div>
        <img src="/assets/images/logo.svg" alt="Vaultex" width="120" class="mb-3">
        <p class="text-muted">Ваши ключи. Ваше будущее.</p>
        <div class="social-links mt-3">
          <a href="https://t.me/vaultex" class="social-link">Telegram</a>
          <a href="https://twitter.com/vaultex" class="social-link">Twitter</a>
          <a href="https://discord.gg/vaultex" class="social-link">Discord</a>
        </div>
      </div>
      <div>
        <h4>Продукт</h4>
        <ul class="footer-links">
          <li><a href="#">Кошелёк</a></li>
          <li><a href="#">Обмен</a></li>
          <li><a href="#">P2P</a></li>
          <li><a href="#">Безопасность</a></li>
        </ul>
      </div>
      <div>
        <h4>Компания</h4>
        <ul class="footer-links">
          <li><a href="#">О нас</a></li>
          <li><a href="#">Контакты</a></li>
          <li><a href="#">Карьера</a></li>
          <li><a href="#">Пресса</a></li>
        </ul>
      </div>
      <div>
        <h4>Поддержка</h4>
        <ul class="footer-links">
          <li><a href="#">Помощь</a></li>
          <li><a href="#">API</a></li>
          <li><a href="#">Статус</a></li>
          <li><a href="#">Сообщество</a></li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2025 Vaultex. {{ lang('footer.rights') }}</p>
      <nav>
        <a href="/privacy">Политика конфиденциальности</a>
        <a href="/terms">Условия использования</a>
      </nav>
    </div>
  </div>
</footer>
{% endblock %}

{% block styles %}
<style>
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(10, 13, 20, 0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--border);
  z-index: 1000;
  padding: 16px 0;
}
.navbar__container {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.navbar__logo img { height: 32px; width: auto; }
.navbar__actions { display: flex; gap: 12px; }

.hero {
  padding: 140px 0 80px;
  min-height: 100vh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}
.hero__bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(61,126,255,0.15) 0%, transparent 50%);
  pointer-events: none;
}
.hero__container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  position: relative;
  z-index: 1;
}
.hero__label { margin-bottom: 24px; }
.hero__title { margin-bottom: 24px; }
.hero__title--accent { color: var(--accent-blue); }
.hero__desc { font-size: 18px; max-width: 500px; margin-bottom: 32px; }
.hero__actions { display: flex; gap: 16px; margin-bottom: 48px; }
.hero__stats { display: flex; gap: 48px; }
.stat__value { display: block; font-size: 32px; font-weight: 700; color: var(--text-primary); font-family: 'Sora', sans-serif; }
.stat__label { font-size: 14px; color: var(--text-secondary); }
.hero__visual img { max-width: 100%; height: auto; }

.banners { padding: 80px 0; }
.banner-card {
  display: block;
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.banner-card img { width: 100%; height: 400px; object-fit: cover; }
.banner-card__text {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32px;
  background: linear-gradient(transparent, rgba(0,0,0,0.8));
  color: white;
}
.banner-card__text h2 { font-size: 28px; margin-bottom: 8px; }
.banner-card__text p { opacity: 0.9; }

.features { padding: 100px 0; }
.feature-card__icon { color: var(--accent-blue); margin-bottom: 20px; }
.feature-card h3 { margin-bottom: 12px; }
.label--soon { 
  display: inline-block;
  margin-top: 12px;
  background: var(--accent-gold-dim);
  color: var(--accent-gold);
  border-color: var(--accent-gold-dim);
}

.coins { padding: 60px 0; background: var(--bg-secondary); }
.coins__scroll {
  display: flex;
  justify-content: center;
  gap: 32px;
  flex-wrap: wrap;
}
.coins__scroll img { opacity: 0.7; transition: opacity 0.2s; }
.coins__scroll img:hover { opacity: 1; }

.cta { padding: 100px 0; }
.cta h2 { margin-bottom: 16px; }

.footer {
  padding: 80px 0 40px;
  border-top: 1px solid var(--border);
}
.footer h4 { margin-bottom: 20px; font-size: 14px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); }
.footer-links { list-style: none; }
.footer-links li { margin-bottom: 12px; }
.footer-links a { color: var(--text-secondary); }
.footer-links a:hover { color: var(--accent-blue); }
.social-links { display: flex; gap: 16px; }
.social-link { color: var(--text-secondary); font-size: 14px; }
.social-link:hover { color: var(--accent-blue); }
.footer__bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 60px;
  padding-top: 32px;
  border-top: 1px solid var(--border);
  color: var(--text-muted);
  font-size: 14px;
}
.footer__bottom nav { display: flex; gap: 24px; }
.footer__bottom a { color: var(--text-muted); }

@media (max-width: 1024px) {
  .hero__container { grid-template-columns: 1fr; text-align: center; }
  .hero__desc { margin-left: auto; margin-right: auto; }
  .hero__actions { justify-content: center; }
  .hero__stats { justify-content: center; }
  .hero__visual { display: none; }
  .grid--4 { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .navbar__actions { display: none; }
  .hero { padding-top: 100px; }
  .hero__stats { flex-direction: column; gap: 24px; }
  .grid--4 { grid-template-columns: 1fr; }
  .footer__bottom { flex-direction: column; gap: 16px; text-align: center; }
}
</style>
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const splide = new Splide('#banner-carousel', {
    type: 'loop',
    autoplay: true,
    interval: 5000,
    pauseOnHover: true,
    rewind: true,
    gap: '1.5rem',
    pagination: true,
    arrows: true,
    breakpoints: {
      768: { gap: '1rem' }
    }
  });
  splide.mount();
});
</script>
{% endblock %}
